# OpenRouter API key — used server-side to analyze and tailor resumes.
# The model is served through OpenRouter (https://openrouter.ai).
# Get a key at https://openrouter.ai/keys
# Copy this file to `.env.local` and fill in your key. Never commit real keys.
OPENROUTER_API_KEY=

# Upstash Redis (REST) — backs the anonymous free-usage quota, per-IP rate
# limiting, and the waitlist. Create a database at https://console.upstash.com
# and copy its REST URL + token here. Optional for local dev: without these,
# the app falls back to an in-memory store (per-process, not shared).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
