# OpenRouter API key — used server-side to analyze and tailor resumes.
# The model is served through OpenRouter (https://openrouter.ai).
# Get a key at https://openrouter.ai/keys
# Copy this file to `.env.local` and fill in your key. Never commit real keys.
OPENROUTER_API_KEY=

# Clerk auth — REQUIRED for the app to boot. Sign-in is optional for users
# (the whole tailoring flow works signed-out), but the ClerkProvider needs these
# keys to render. Grab free test keys (pk_test_… / sk_test_…) from the Clerk
# dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Canonical site URL (optional) — used for absolute Open Graph / Twitter
# share-image links. Falls back to the Vercel production URL, then localhost.
NEXT_PUBLIC_SITE_URL=

# Upstash Redis (REST) — backs the anonymous free-usage quota, per-IP rate
# limiting, saved resume versions, and the waitlist. Optional for local dev:
# without these, the app falls back to an in-memory store (per-process, not shared).
#
# The code accepts EITHER naming scheme:
#   - Upstash console:        UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   - Vercel Marketplace add-on: KV_REST_API_URL / KV_REST_API_TOKEN
# Use the REST URL + the (read/write) REST token — NOT the read-only token and
# NOT the rediss:// connection string.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Beta access codes (optional) — comma-separated secret codes that grant
# UNLIMITED tailors, bypassing the free-tailor quota (per-IP rate limiting still
# applies). Share a link like https://your-app/app?code=<code> with testers.
# Rotate/remove a value here to revoke it. Leave empty to disable beta access.
BETA_ACCESS_CODES=
